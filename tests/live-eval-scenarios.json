    {
      "scenario_id": "WR-EXPLICIT-INTAKE",
      "schema_version": 1,
      "tags": ["workflow", "workflow-intake", "routing"],
      "prompt": "Use $workflow to plan this multi-step dashboard change.",
      "required_paths": ["route", "reason"],
      "required_values": {"route": "workflow-intake"},
      "forbidden_values": ["adversarial-review-loop"],
      "expected_status": "pass",
      "timeout_seconds": 120
    },
    {
      "scenario_id": "WR-EXPLICIT-REVIEW",
      "schema_version": 1,
      "tags": ["workflow", "adversarial-review-loop", "routing"],
      "prompt": "Use $workflow to review this diff and residual risk.",
      "required_paths": ["route", "reason"],
      "required_values": {"route": "adversarial-review-loop"},
      "forbidden_values": ["workflow-intake"],
      "expected_status": "pass",
      "timeout_seconds": 120
    },
    {
      "scenario_id": "WR-SIMPLE-ONE-SHOT",
      "schema_version": 1,
      "tags": ["workflow", "routing", "simple-task"],
      "prompt": "Fix this typo in README.",
      "required_paths": ["route", "reason"],
      "required_values": {"route": null},
      "forbidden_values": ["workflow", "workflow-intake", "adversarial-review-loop"],
      "expected_status": "pass",
      "timeout_seconds": 120
    },
    {
      "scenario_id": "WI-AMBIGUOUS-FULL-AUTO",
      "schema_version": 1,
