      "required_values": {"autonomy_level": "L0"},
      "forbidden_values": ["implemented", "L4-approved"],
      "expected_status": "blocked",
      "timeout_seconds": 120
    },
    {
      "scenario_id": "WI-SIMPLE-DOCS",
      "schema_version": 1,
      "tags": ["workflow-intake", "simple-task", "docs"],
