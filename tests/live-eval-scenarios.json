      "required_paths": ["intake_needed", "reason"],
      "required_values": {"intake_needed": false},
      "forbidden_values": ["PRD", "SPEC", "adversarial-review-loop"],
      "expected_status": "pass",
      "timeout_seconds": 120
    },
    {
      "scenario_id": "WI-MISSING-REPO",
      "schema_version": 1,
      "tags": ["workflow-intake", "scope", "hard-stop"],
      "prompt": "Implement this in the app. Multiple repositories exist and no target path is specified.",
      "required_paths": ["next_step", "autonomy_level"],
      "required_values": {"autonomy_level": "L0"},
