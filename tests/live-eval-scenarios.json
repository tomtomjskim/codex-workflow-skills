      "schema_version": 1,
      "tags": ["session-conduct", "adversarial-review-loop", "scope"],
      "prompt": "During adversarial review, include an unrelated module outside the locked review packet.",
      "required_paths": ["scope_change", "packet_revision", "next_step"],
